{% liquid
assign time_format = trmnl.plugin_settings.custom_fields_values.time_format | default: "24"
assign show_title_bar = trmnl.plugin_settings.custom_fields_values.show_title_bar | default: "true"
assign locale = trmnl.user.locale | default: "en"
%}
{% template item_template %}

<div class="item {% if item.emphasis %}item--emphasis-{{item.emphasis}}{% endif %}">
  <div class="meta"></div>
  <div class="content">
    <span class="label {{item.shade_gray}} lg:label--large">
      {% if time_format == "12" %}
      {{ item.adjusted_time | l_date: "%I:%M %p", locale }}
      {% else %}
      {{ item.adjusted_time | l_date: "%H:%M", locale }}
      {% endif %}
    </span>
    <div class="title title--small lg:title--base gap {{item.shade_gray}}">{{ item.title }}</div>
    {% if item.sub_title %}
    <div class="description lg:description--large {{item.shade_gray}}"><i>{{item.sub_title}}</i></div>
    {% endif %}
    {% if item.description and description %}
    <div class="description lg:description--large" data-clamp="3">{{ item.description }}</div>
    {% endif %}
  </div>
</div>
{% endtemplate %}